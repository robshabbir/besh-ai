{
  "name": "calva-ai-receptionist",
  "version": "2.0.0",
  "description": "Multi-tenant AI-powered receptionist platform using Twilio Voice and Claude",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node seed.js",
    "setup": "npm run migrate && npm run seed",
    "setup-tts": "pip3 install edge-tts",
    "test": "./test.sh",
    "clean-tts-cache": "node -e \"require('./src/services/tts').cleanOldCache(7)\""
  },
  "keywords": [
    "ai",
    "receptionist",
    "twilio",
    "claude",
    "voice",
    "saas",
    "multi-tenant"
  ],
  "author": "Calva AI",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "stripe": "^20.3.1",
    "twilio": "^5.12.1",
    "uuid": "^11.0.4",
    "validator": "^13.15.26",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
