# Calva AI Receptionist — Production Environment Variables
# Copy to .env and fill in all required values

# ============= REQUIRED =============

PORT=3100
NODE_ENV=production
SESSION_SECRET=          # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
BASE_URL=https://your-domain.com
APP_URL=https://your-domain.com

# Twilio (voice calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI (Gemini for conversation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Voice (ElevenLabs TTS)
ELEVENLABS_API_KEY=
CR_VOICE=cgSgspJ2msm6clMCkdW9-1.0_0.3_0.7
CR_TTS_PROVIDER=ElevenLabs
VOICE_NAME=en-US-Chirp3-HD-Aoede

# Deepgram (speech-to-text for Media Streams)
DEEPGRAM_API_KEY=

# Stripe (billing — required for paid subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Email (SMTP — required for verification & password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@calva.ai

# ============= OPTIONAL =============

# CORS (comma-separated allowed origins)
CORS_ORIGINS=https://your-domain.com

# N8N webhook for booking notifications
N8N_WEBHOOK_URL=
