  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 px-6 py-4 space-y-3">
    <a href="#features" class="block text-sm text-dark-400 hover:text-white py-2" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Features</a>
    <a href="#industries" class="block text-sm text-dark-400 hover:text-white py-2" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Industries</a>
    <a href="#demo" class="block text-sm text-dark-400 hover:text-white py-2" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Demo</a>
    <a href="#pricing" class="block text-sm text-dark-400 hover:text-white py-2" onclick="document.getElementById('mobile-menu').classList.add('hidden')">Pricing</a>
    <a href="#faq" class="block text-sm text-dark-400 hover:text-white py-2" onclick="document.getElementById('mobile-menu').classList.add('hidden')">FAQ</a>
    <div class="pt-2 border-t border-white/5 flex gap-3">
      <a href="/login.html" class="text-sm text-dark-400 hover:text-white py-2">Log In</a>
      <a href="/onboard.html" class="btn-primary text-sm font-semibold text-white px-5 py-2.5 rounded-lg">Start Free Trial</a>
