<!-- ==================== ROI CALCULATOR ==================== -->
<section class="py-24">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-12 fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Calculate your <span class="gradient-text">ROI</span></h2>
      <p class="text-lg text-dark-400">See how much revenue Calva could recover for your business.</p>
    </div>
    <div class="fade-up glass rounded-2xl p-8 glow-blue">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Calls you miss per week</label>
            <input type="range" id="roi-missed" min="1" max="50" value="10" class="w-full accent-brand-500" oninput="calcROI()">
            <div class="flex justify-between text-xs text-dark-500 mt-1"><span>1</span><span id="roi-missed-val" class="text-brand-400 font-bold">10</span><span>50</span></div>
          </div>
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Average job/client value ($)</label>
            <input type="range" id="roi-value" min="50" max="5000" value="500" step="50" class="w-full accent-brand-500" oninput="calcROI()">
            <div class="flex justify-between text-xs text-dark-500 mt-1"><span>$50</span><span id="roi-value-val" class="text-brand-400 font-bold">$500</span><span>$5,000</span></div>
          </div>
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Conversion rate of answered calls</label>
            <input type="range" id="roi-rate" min="5" max="50" value="20" class="w-full accent-brand-500" oninput="calcROI()">
            <div class="flex justify-between text-xs text-dark-500 mt-1"><span>5%</span><span id="roi-rate-val" class="text-brand-400 font-bold">20%</span><span>50%</span></div>
          </div>
        </div>
        <div class="flex flex-col items-center justify-center text-center bg-dark-900/50 rounded-xl p-8">
          <p class="text-sm text-dark-400 mb-2">You're leaving on the table each month:</p>
          <p id="roi-lost" class="text-5xl font-black text-red-400 mb-4">$4,000</p>
          <div class="w-full border-t border-white/10 pt-4 mt-4">
            <p class="text-sm text-dark-400 mb-2">With Calva (starting at $49/mo):</p>
            <p id="roi-recovered" class="text-4xl font-black text-green-400 mb-1">+$3,951</p>
            <p class="text-sm text-dark-500">recovered revenue per month</p>
          </div>
          <a href="/onboard.html" class="mt-6 btn-primary text-sm font-semibold text-white px-6 py-3 rounded-xl">Start Recovering Revenue →</a>
        </div>
