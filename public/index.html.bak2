<!-- ==================== PROBLEM/SOLUTION ==================== -->
<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="fade-up">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
          Every missed call is a<br><span class="text-red-400">lost customer.</span>
        </h2>
        <div class="space-y-4 text-dark-400">
          <div class="flex items-start gap-3">
            <span class="text-red-400 mt-1">✕</span>
            <p><strong class="text-dark-200">62% of calls</strong> to small businesses go unanswered</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red-400 mt-1">✕</span>
            <p><strong class="text-dark-200">85% of callers</strong> who can't reach you won't call back</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red-400 mt-1">✕</span>
            <p><strong class="text-dark-200">$1,200/month</strong> lost on average from missed calls</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-red-400 mt-1">✕</span>
            <p>Traditional answering services cost <strong class="text-dark-200">$300–800/mo</strong> and still sound scripted</p>
          </div>
        </div>
      </div>
      <div class="fade-up fade-up-delay-2">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
          Calva answers every call<br><span class="gradient-text">like your best employee.</span>
        </h2>
        <div class="space-y-4 text-dark-400">
          <div class="flex items-start gap-3">
            <span class="text-green-400 mt-1">✓</span>
            <p><strong class="text-dark-200">24/7 coverage</strong> — nights, weekends, holidays</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-green-400 mt-1">✓</span>
            <p><strong class="text-dark-200">Sounds human</strong> — callers genuinely can't tell the difference</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-green-400 mt-1">✓</span>
            <p><strong class="text-dark-200">Captures every lead</strong> — name, number, what they need, tagged and logged</p>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-green-400 mt-1">✓</span>
            <p>Starts at <strong class="text-dark-200">$49/month</strong> — 10x cheaper than a human receptionist</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== DEMO SECTION ==================== -->
<section id="demo" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-brand-600/[0.03] to-transparent pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 fade-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Hear Calva in Action</h2>
      <p class="text-lg text-dark-400 max-w-2xl mx-auto">Don't take our word for it. Call our demo line or listen to these real conversations.</p>
    </div>

    <!-- Call CTA -->
    <div class="max-w-2xl mx-auto mb-16 fade-up">
      <div class="glass rounded-2xl p-8 text-center glow-blue">
