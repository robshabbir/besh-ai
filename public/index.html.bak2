    </div>
    <div class="border-t border-white/5 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-dark-600">© 2026 Calva AI. All rights reserved.</p>
      <div class="flex gap-6 text-xs text-dark-600">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<script>
// Intersection Observer for fade-up animations
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

// Industry tabs
document.querySelectorAll('.industry-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.industry-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const target = tab.dataset.tab;
    document.querySelectorAll('.industry-panel').forEach(p => p.classList.add('hidden'));
    document.querySelector(`[data-panel="${target}"]`).classList.remove('hidden');
  });
});

// FAQ accordion
function toggleFaq(btn) {
  const answer = btn.nextElementSibling;
  const chevron = btn.querySelector('.faq-chevron');
  const isOpen = !answer.classList.contains('hidden');
  
  // Close all
  document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
  document.querySelectorAll('.faq-chevron').forEach(c => c.style.transform = '');
  
  if (!isOpen) {
    answer.classList.remove('hidden');
    chevron.style.transform = 'rotate(180deg)';
  }
}

// ROI Calculator
function calcROI() {
  const missed = parseInt(document.getElementById('roi-missed').value);
  const value = parseInt(document.getElementById('roi-value').value);
  const rate = parseInt(document.getElementById('roi-rate').value);
  document.getElementById('roi-missed-val').textContent = missed;
  document.getElementById('roi-value-val').textContent = '$' + value.toLocaleString();
  document.getElementById('roi-rate-val').textContent = rate + '%';
  const monthlyLost = Math.round(missed * 4.33 * value * (rate / 100));
  const recovered = monthlyLost - 49;
  document.getElementById('roi-lost').textContent = '$' + monthlyLost.toLocaleString();
  document.getElementById('roi-recovered').textContent = '+$' + Math.max(0, recovered).toLocaleString();
}
calcROI();

// Animated hero conversation — auto-type effect
(function() {
  const convo = document.getElementById('hero-conversation');
  if (!convo) return;
  const bubbles = convo.children;
  // Initially hide all, then reveal one by one
  Array.from(bubbles).forEach((b, i) => {
    b.style.opacity = '0';
    b.style.transform = 'translateY(10px)';
    b.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  });
  let idx = 0;
  function revealNext() {
    if (idx >= bubbles.length) return;
    bubbles[idx].style.opacity = '1';
    bubbles[idx].style.transform = 'translateY(0)';
    idx++;
    if (idx < bubbles.length) {
      const delay = bubbles[idx].classList.contains('bubble-ai') ? 1200 : 2000;
      setTimeout(revealNext, delay);
    }
  }
  // Start after page loads with delay
  setTimeout(revealNext, 1500);
})();

// Smooth scroll for anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function(e) {
    e.preventDefault();
    const target = document.querySelector(this.getAttribute('href'));
    if (target) {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
});

// Navbar background on scroll
const nav = document.querySelector('nav');
window.addEventListener('scroll', () => {
  if (window.scrollY > 50) {
    nav.classList.add('border-white/10');
  } else {
    nav.classList.remove('border-white/10');
  }
});
</script>
</body>
</html>
