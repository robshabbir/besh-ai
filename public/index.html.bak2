          <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <span class="text-lg font-bold text-white">Calva<span class="text-brand-400">.ai</span></span>
        </div>
        <p class="text-sm text-dark-500">AI receptionist that sounds human.<br>Every call, covered. 24/7.</p>
      </div>
      <div>
        <h4 class="font-semibold text-white mb-4">Product</h4>
        <ul class="space-y-2 text-sm text-dark-500">
          <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
          <li><a href="#pricing" class="hover:text-white transition-colors">Pricing</a></li>
          <li><a href="#industries" class="hover:text-white transition-colors">Industries</a></li>
          <li><a href="#demo" class="hover:text-white transition-colors">Live Demo</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold text-white mb-4">Account</h4>
        <ul class="space-y-2 text-sm text-dark-500">
          <li><a href="/login.html" class="hover:text-white transition-colors">Log In</a></li>
          <li><a href="/onboard.html" class="hover:text-white transition-colors">Sign Up</a></li>
          <li><a href="/dashboard/" class="hover:text-white transition-colors">Dashboard</a></li>
          <li><a href="/setup-forwarding.html" class="hover:text-white transition-colors">Setup Guide</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold text-white mb-4">Contact</h4>
        <ul class="space-y-2 text-sm text-dark-500">
          <li><a href="mailto:hello@calva.ai" class="hover:text-white transition-colors">hello@calva.ai</a></li>
          <li><a href="tel:+19297557288" class="hover:text-white transition-colors">(929) 755-7288</a></li>
        </ul>
