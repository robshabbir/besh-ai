<!-- ==================== HERO ==================== -->
<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <div class="hero-glow"></div>
  <div class="max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center relative z-10">
    <!-- Left: Copy -->
    <div class="fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass text-xs text-brand-300 font-medium mb-6">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Live — answering calls right now
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-[1.05] tracking-tight mb-6">
        Your phone.<br>
        <span class="gradient-text">Always answered.</span>
      </h1>
      <p class="text-lg sm:text-xl text-dark-400 leading-relaxed mb-8 max-w-lg">
        Calva is an AI receptionist that sounds so human, callers can't tell the difference. It books appointments, captures leads, and handles emergencies — 24/7, for a fraction of the cost.
      </p>
      <div class="flex flex-wrap gap-4 mb-10">
        <a href="/onboard.html" class="btn-primary text-base font-semibold text-white px-8 py-4 rounded-xl inline-flex items-center gap-2">
          Try Free for 14 Days
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="#demo" class="glass glass-hover text-base font-medium text-white px-8 py-4 rounded-xl inline-flex items-center gap-2 transition-all">
          <svg class="w-5 h-5 text-brand-400" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          Hear a Demo
        </a>
      </div>
      <div class="flex items-center gap-6 text-sm text-dark-500">
        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg> No credit card</span>
        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg> 5-min setup</span>
        <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg> Cancel anytime</span>
      </div>
    </div>

    <!-- Right: Conversation demo -->
    <div class="fade-up fade-up-delay-2 relative">
      <div class="absolute -inset-4 bg-gradient-to-r from-brand-600/10 to-purple-600/10 rounded-3xl blur-3xl"></div>
      <div class="relative glass rounded-2xl p-6 space-y-4 glow-blue">
        <!-- Call header -->
        <div class="flex items-center justify-between pb-4 border-b border-white/5">
          <div class="flex items-center gap-3">
            <div class="relative">
              <div class="w-10 h-10 rounded-full bg-brand-600/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-400 rounded-full border-2 border-dark-950"></div>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Calva AI</p>
              <p class="text-xs text-green-400">Active call · 0:47</p>
            </div>
          </div>
          <div class="flex items-center gap-1.5" id="hero-waveform">
            <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
            <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
          </div>
        </div>
        <!-- Conversation bubbles -->
        <div class="space-y-3 text-sm" id="hero-conversation">
          <div class="bubble-caller px-4 py-3 max-w-[85%]">
            <p class="text-xs text-dark-500 mb-1">Caller</p>
            <p class="text-dark-200">Hi, I've got a pipe leaking under my kitchen sink and it's getting pretty bad.</p>
          </div>
          <div class="bubble-ai px-4 py-3 max-w-[85%] ml-auto">
            <p class="text-xs text-brand-300 mb-1">Calva AI</p>
            <p class="text-dark-100">Oh no, how bad is it? Like is it spraying or more of a slow drip?</p>
          </div>
          <div class="bubble-caller px-4 py-3 max-w-[85%]">
            <p class="text-xs text-dark-500 mb-1">Caller</p>
            <p class="text-dark-200">It's a steady stream, I've got towels down but they're soaking through.</p>
          </div>
          <div class="bubble-ai px-4 py-3 max-w-[85%] ml-auto">
            <p class="text-xs text-brand-300 mb-1">Calva AI</p>
            <p class="text-dark-100">Yikes, okay. First thing — there should be a shut-off valve under the sink, turn that clockwise to stop the flow. What's your address? I'm gonna get someone out to you ASAP.</p>
          </div>
        </div>
        <!-- Bottom bar -->
        <div class="flex items-center gap-3 pt-3 border-t border-white/5">
          <div class="flex-1 flex items-center gap-2 px-3 py-2 rounded-lg bg-dark-900/50">
            <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
            <span class="text-xs text-dark-400">AI is listening...</span>
          </div>
          <span class="text-xs text-dark-600">Powered by Calva</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== SOCIAL PROOF BAR ==================== -->
<section class="border-y border-white/5 py-10">
  <div class="max-w-7xl mx-auto px-6">
