                            📞 Call Me Now
                        </button>
                    </div>
                    <div id="demoStatus" class="demo-status"></div>
                    <p class="demo-disclaimer">
                        3 demo calls per hour. No spam, ever.<br>
                        <strong>Or just call:</strong> <a href="tel:+19297557288">(929) 755-7288</a>
                    </p>
                </form>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="fade-in">
        <div class="container">
            <div class="section-header">
                <h2>Get Started in 3 Simple Steps</h2>
                <p class="section-subtitle">Go from zero to AI receptionist in under 5 minutes</p>
            </div>
            <div class="steps-container">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <span class="step-icon">📱</span>
                    <h3>Forward Your Calls</h3>
                    <p>Use your existing number or get a new one. Forward calls to Calva—setup takes 60 seconds.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <span class="step-icon">🧠</span>
                    <h3>AI Answers Like a Human</h3>
                    <p>Calva greets callers, answers questions, books appointments, and captures leads—automatically.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <span class="step-icon">💬</span>
                    <h3>Get Text Summaries</h3>
                    <p>Receive instant SMS alerts with caller details, transcripts, and next steps. Stay in control.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Audio Demos -->
    <section class="fade-in" style="background: linear-gradient(180deg, rgba(59, 130, 246, 0.02) 0%, rgba(139, 92, 246, 0.02) 100%);">
        <div class="container">
            <div class="section-header">
                <h2>Hear Calva in Action</h2>
                <p class="section-subtitle">Real AI-generated voices. This is exactly how Calva sounds to your callers.</p>
            </div>
            <div class="audio-grid">
                <div class="audio-card">
                    <div class="audio-header">
                        <span class="audio-icon">🔧</span>
                        <div>
                            <div class="audio-title">Plumbing Emergency</div>
                            <div class="audio-subtitle">Urgent dispatch handling</div>
                        </div>
                    </div>
                    <p class="audio-description">
