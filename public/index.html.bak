                    <h4>Legal</h4>
                    <a href="#pricing">Privacy Policy</a>
                    <a href="#pricing">Terms of Service</a>
                    <a href="#pricing">HIPAA Compliance</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Calva AI. All rights reserved.</p>
                <p class="footer-tagline">Powered by AI. Built for humans.</p>
            </div>
        </div>
    </footer>

    <script>
        // Phone number formatting
        const phoneInput = document.getElementById('demoPhone');
        if (phoneInput) {
            phoneInput.addEventListener('input', function(e) {
                let x = e.target.value.replace(/\D/g, '').match(/(\d{0,3})(\d{0,3})(\d{0,4})/);
                e.target.value = !x[2] ? x[1] : '(' + x[1] + ') ' + x[2] + (x[3] ? '-' + x[3] : '');
            });
        }

        // Demo call function
        async function triggerDemoCall(e) {
            e.preventDefault();
            
            const phoneInput = document.getElementById('demoPhone');
            const statusDiv = document.getElementById('demoStatus');
            const btn = document.getElementById('demoBtn');
            
            const phone = phoneInput.value.replace(/\D/g, '');
            
            if (phone.length !== 10) {
                statusDiv.textContent = '⚠️ Please enter a valid 10-digit phone number';
                statusDiv.className = 'demo-status error';
                return;
            }
            
            btn.disabled = true;
            btn.innerHTML = '<span class="loading"></span> Calling...';
            statusDiv.innerHTML = '📞 Calling you now... Pick up your phone!';
            statusDiv.className = 'demo-status';
            
            try {
                const response = await fetch('/api/demo-call', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        phone: '+1' + phone,
                        industry: 'plumber'
                    })
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    statusDiv.textContent = '✅ ' + (data.message || 'Calling you now! Pick up your phone.');
                    statusDiv.className = 'demo-status success';
                    phoneInput.value = '';
                    
                    // Show satisfaction survey after call
                    setTimeout(() => {
                        statusDiv.innerHTML = 'How was it? <span style="font-size: 24px;">⭐⭐⭐⭐⭐</span>';
                    }, 30000); // 30 seconds later
                } else {
                    statusDiv.textContent = '⚠️ ' + (data.error || 'Unable to place call. Try calling (929) 755-7288 instead.');
                    statusDiv.className = 'demo-status error';
                }
            } catch (error) {
                statusDiv.textContent = '⚠️ Network error. Try calling (929) 755-7288 instead.';
                statusDiv.className = 'demo-status error';
            } finally {
                btn.disabled = false;
                btn.textContent = '📞 Call Me Now';
                
                setTimeout(() => {
                    statusDiv.textContent = '';
                    statusDiv.className = 'demo-status';
                }, 15000);
            }
        }

        // Audio waveform animations
        function startWave(id) {
            const player = document.getElementById('player-' + id);
            if (player) {
                player.classList.add('playing');
            }
        }
        
        function stopWave(id) {
            const player = document.getElementById('player-' + id);
            if (player) {
                player.classList.remove('playing');
            }
        }

        // FAQ toggle
        function toggleFAQ(button) {
            const item = button.parentElement;
            const wasActive = item.classList.contains('active');
            
            // Close all items
            document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
            
            // Open clicked item if it wasn't active
            if (!wasActive) {
                item.classList.add('active');
            }
        }

        // Scroll reveal animations
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -80px 0px'
        };

        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => {
            observer.observe(el);
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>
