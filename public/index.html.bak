    <!-- Features -->
    <section class="fade-in">
        <div class="container">
            <div class="section-header">
                <h2>Everything You Need</h2>
                <p class="section-subtitle">Powerful features that make your business run smoother</p>
            </div>
            <div class="features-grid">
                <div class="feature-card">
                    <span class="feature-icon">📞</span>
                    <h3>24/7 Answering</h3>
                    <p>Never miss a call. Calva answers instantly, day or night, weekends and holidays.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">📅</span>
                    <h3>Appointment Booking</h3>
                    <p>Integrates with Google Calendar, Outlook, and Calendly. Books appointments automatically.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">📝</span>
                    <h3>Call Recording</h3>
                    <p>Every call recorded and transcribed. Review conversations anytime from your dashboard.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">💬</span>
                    <h3>SMS Summaries</h3>
                    <p>Get instant text alerts with caller details and transcripts. Stay in the loop.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">🌎</span>
                    <h3>Spanish Support</h3>
                    <p>Bilingual AI receptionist speaks fluent Spanish and English. Serve more customers.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">📚</span>
                    <h3>Custom Knowledge</h3>
                    <p>Train Calva on your business info, FAQs, and pricing. Answers like your team.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">☎️</span>
                    <h3>Human Handoff</h3>
                    <p>Transfer urgent calls to you instantly. Set custom rules and priority contacts.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">💻</span>
                    <h3>Chat Widget</h3>
                    <p>Add Calva to your website as a live chat. Capture leads 24/7 across all channels.</p>
                </div>
                <div class="feature-card">
                    <span class="feature-icon">📊</span>
                    <h3>Analytics Dashboard</h3>
                    <p>Track calls, conversion rates, and ROI with detailed analytics and insights.</p>
                </div>
            </div>
        </div>
    </section>

