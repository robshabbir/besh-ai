                    </div>
                    <div class="badge">
                        <span class="badge-icon">🎙️</span>
                        <span>Natural Voice</span>
                    </div>
                    <div class="badge">
                        <span class="badge-icon">⚡</span>
                        <span>Setup in 5 min</span>
                    </div>
                    <div class="badge">
                        <span class="badge-icon">💰</span>
                        <span>From $99/mo</span>
                    </div>
                </div>
                
                <div class="cta-group">
                    <a href="#try-live" class="btn btn-primary">Try It Live — We'll Call You</a>
                    <a href="tel:+19297557288" class="btn btn-secondary">📞 Call (929) 755-7288</a>
                </div>
                
                <div class="social-proof">
                    <span class="proof-number">500+</span>
                    Calls answered and counting
                </div>
                
                <p class="phone-link">Hear Calva answer live: <a href="tel:+19297557288">(929) 755-7288</a></p>
            </div>
        </div>
    </section>

    <!-- Try It Live Section -->
    <section class="try-live fade-in" id="try-live">
        <div class="container">
            <div class="section-header">
                <h2><span class="gradient-text">Try It Right Now</span></h2>
                <p class="section-subtitle">
                    Enter your number. We'll call you in seconds. Talk to Calva—our actual AI receptionist.
                </p>
            </div>
            <div class="try-live-card">
                <form id="demoForm" onsubmit="triggerDemoCall(event)">
                    <div class="form-row">
                        <input 
                            type="tel" 
                            id="demoPhone" 
                            placeholder="(555) 123-4567" 
                            required
                            maxlength="17"
                        />
